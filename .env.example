# --- Gemini (required) ---
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash-native-audio-latest
GEMINI_VOICE=Puck

# --- Restaurant identity (shown to callers, edit for your real restaurant) ---
RESTAURANT_NAME=Debs
RESTAURANT_HOURS=12 PM - 3 AM
RESTAURANT_ADDRESS=Going Hells 1234
RESTAURANT_PHONE=1234

# --- Database ---
DATABASE_URL=sqlite:///./restaurant.db

# --- Twilio (only needed for real inbound phone calls) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Server ---
HOST=0.0.0.0
PORT=8000
