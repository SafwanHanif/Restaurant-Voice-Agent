# === Gemini ===
GEMINI_API_KEY=your_gemini_api_key_here

# === Database ===
# SQLite for dev:  sqlite+aiosqlite:///./restaurant_voice.db
# PostgreSQL for prod: postgresql+asyncpg://user:pass@host:5432/restaurant_voice
DATABASE_URL=sqlite+aiosqlite:///./restaurant_voice.db

# === Square (optional) ===
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=

# === App ===
APP_NAME=Bella Italia Voice Agent
RESTAURANT_NAME=Bella Italia
LOG_LEVEL=INFO
